/**calculator/pages/index/index.wxss**/
.calculator-card {
  padding: 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: var(--text);
  margin-bottom: 12rpx;
}

input, .picker {
  background: var(--bg);
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--text);
}

.factors-section {
  margin-top: 40rpx;
  padding-top: 40rpx;
  border-top: 1rpx solid var(--border);
}

.section-title {
  display: block;
  font-size: 28rpx;
  color: var(--text);
  margin-bottom: 20rpx;
}

.factor-item {
  margin-bottom: 20rpx;
}

.factor-label {
  display: block;
  font-size: 26rpx;
  color: var(--text-light);
  margin-bottom: 10rpx;
}

.result-card {
  text-align: center;
  padding: 60rpx 40rpx;
  margin-top: 30rpx;
}

.result-score {
  font-size: 80rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.result-level {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 20rpx;
}

.result-suggestion {
  display: block;
  font-size: 28rpx;
  color: var(--text);
  margin-bottom: 16rpx;
}

.result-besttime {
  display: block;
  font-size: 26rpx;
  color: var(--text-light);
  margin-bottom: 20rpx;
}

.result-runway {
  display: block;
  font-size: 26rpx;
  color: var(--secondary);
  background: #E0F7FA;
  padding: 16rpx;
  border-radius: 12rpx;
}
