/**pages/index/index.wxss**/
.header {
  margin-bottom: 30rpx;
}

.greeting {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text);
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: var(--text-light);
  margin-top: 10rpx;
  display: block;
}

/* 运势卡片 */
.fortune-card {
  position: relative;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: var(--white);
}

.fortune-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.fortune-title {
  font-size: 32rpx;
  font-weight: 600;
}

.fortune-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 20rpx;
}

.fortune-status.pending {
  background: rgba(255,255,255,0.5);
}

.fortune-content {
  text-align: center;
  padding: 20rpx 0;
}

.fortune-level {
  font-size: 48rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 10rpx;
}

.fortune-text {
  font-size: 28rpx;
  opacity: 0.95;
}

.fortune-empty {
  text-align: center;
  padding: 40rpx 0;
  font-size: 28rpx;
  opacity: 0.9;
}

.card-arrow {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 40rpx;
  opacity: 0.7;
}

/* 功能入口 */
.feature-grid {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.feature-item {
  flex: 1;
  background: var(--white);
  border-radius: var(--radius);
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: var(--shadow);
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin: 0 auto 16rpx;
}

.feature-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text);
  display: block;
}

.feature-desc {
  font-size: 24rpx;
  color: var(--text-lighter);
  margin-top: 6rpx;
  display: block;
}

/* 区域标题 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
}

.section-more {
  font-size: 26rpx;
  color: var(--primary);
}

/* 倒计时 */
.countdown-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.countdown-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.countdown-item:last-child {
  border-bottom: none;
}

.countdown-title {
  font-size: 30rpx;
  color: var(--text);
  display: block;
}

.countdown-date {
  font-size: 24rpx;
  color: var(--text-lighter);
  margin-top: 6rpx;
  display: block;
}

.countdown-days {
  display: flex;
  align-items: baseline;
}

.days-number {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary);
}

.days-text {
  font-size: 24rpx;
  color: var(--text-light);
  margin-left: 4rpx;
}

/* 热门帖子 */
.post-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.post-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.post-item:last-child {
  border-bottom: none;
}

.post-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.post-category {
  font-size: 24rpx;
  color: var(--primary);
  background: var(--primary-light);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.post-time {
  font-size: 24rpx;
  color: var(--text-lighter);
}

.post-content {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.6;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.post-footer {
  margin-top: 12rpx;
}

.post-stats {
  font-size: 24rpx;
  color: var(--text-lighter);
}
