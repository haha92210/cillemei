/**pages/fortune/fortune.wxss**/

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid var(--primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 30rpx;
  font-size: 28rpx;
  color: var(--text-light);
}

/* 错误状态 */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 28rpx;
  color: var(--text-light);
  margin-bottom: 30rpx;
}

/* 运势卡片 */
.fortune-card {
  background: white;
  border-radius: 24rpx;
  border: 4rpx solid;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.fortune-header {
  padding: 40rpx;
  text-align: center;
  color: white;
}

.fortune-level {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.fortune-score {
  display: block;
  font-size: 28rpx;
  opacity: 0.9;
}

.fortune-body {
  padding: 40rpx;
}

.fortune-main {
  text-align: center;
  margin-bottom: 40rpx;
}

.fortune-category {
  display: inline-block;
  background: var(--primary-light);
  color: var(--primary);
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.fortune-content {
  display: block;
  font-size: 32rpx;
  color: var(--text);
  font-weight: 600;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.fortune-advice {
  display: block;
  font-size: 26rpx;
  color: var(--text-light);
  line-height: 1.5;
}

/* 维度评分 */
.dimensions-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 20rpx;
}

.dimensions-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.dimension-item {
  background: #f8f9fa;
  padding: 24rpx;
  border-radius: 16rpx;
}

.dimension-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.dimension-label {
  font-size: 24rpx;
  color: var(--text-light);
}

.dimension-desc {
  font-size: 20rpx;
  color: #999;
  background: white;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.dimension-score {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.dimension-bar {
  height: 8rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
  overflow: hidden;
}

.dimension-bar-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.5s ease;
}

/* 幸运元素 */
.lucky-section {
  display: flex;
  justify-content: space-around;
  background: linear-gradient(135deg, #fff9e6, #fff5d6);
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 40rpx;
}

.lucky-item {
  text-align: center;
}

.lucky-icon {
  display: block;
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.lucky-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-light);
  margin-bottom: 4rpx;
}

.lucky-value {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text);
}

/* 宜忌 */
.suitable-section {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.suitable-box, .avoid-box {
  padding: 20rpx;
  border-radius: 12rpx;
}

.suitable-box {
  background: #e8f5e9;
}

.avoid-box {
  background: #ffebee;
}

.suitable-title, .avoid-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.suitable-title {
  color: #4CAF50;
}

.avoid-title {
  color: #F44336;
}

.suitable-item, .avoid-item {
  display: inline-block;
  font-size: 22rpx;
  margin: 4rpx;
  padding: 6rpx 12rpx;
  background: white;
  border-radius: 8rpx;
}

/* 操作按钮 */
.fortune-actions {
  display: flex;
  gap: 20rpx;
  padding: 0 40rpx 40rpx;
}

.fortune-actions .btn {
  flex: 1;
}

/* 抽签卡片 */
.draw-card {
  background: white;
  border-radius: 24rpx;
  padding: 80rpx 60rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.draw-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.draw-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 20rpx;
}

.draw-hint {
  display: block;
  font-size: 28rpx;
  color: var(--text-light);
  line-height: 1.6;
  margin-bottom: 50rpx;
}

.btn-large {
  padding: 30rpx 60rpx !important;
  font-size: 32rpx !important;
}

.btn-icon {
  margin-right: 10rpx;
}
