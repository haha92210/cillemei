<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户信息 -->
  <view class="user-card">
    <view class="user-avatar">
      <open-data type="userAvatarUrl"></open-data>
    </view>
    <view class="user-info">
      <open-data type="userNickName" class="user-name"></open-data>
      <text class="user-id">ID: {{userId}}</text>
    </view>
  </view>
  
  <!-- 数据统计 -->
  <view class="card stats-card">
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-value">{{stats.fortuneCount}}</text>
        <text class="stat-label">抽签次数</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.postCount}}</text>
        <text class="stat-label">发帖数</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.calculatorCount}}</text>
        <text class="stat-label">计算器</text>
      </view>
    </view>
  </view>
  
  <!-- 功能菜单 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goToHistory">
      <text class="menu-icon">📜</text>
      <text class="menu-text">运势历史</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToMyPosts">
      <text class="menu-icon">📝</text>
      <text class="menu-text">我的树洞</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToCalculatorHistory">
      <text class="menu-icon">🧮</text>
      <text class="menu-text">计算器记录</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
  
  <!-- 设置 -->
  <view class="menu-list">
    <view class="menu-item">
      <text class="menu-icon">🔔</text>
      <text class="menu-text">消息通知</text>
      <switch checked="{{settings.notifications}}" bindchange="toggleNotification"/>
    </view>
    <view class="menu-item" bindtap="clearCache">
      <text class="menu-icon">🗑️</text>
      <text class="menu-text">清除缓存</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="about">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于辞了没</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
  
  <view class="version">版本 1.0.0</view>
</view>
