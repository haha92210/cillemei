/**posts/pages/detail/detail.wxss**/

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid var(--primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 帖子详情 */
.post-detail {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

/* 帖子头部 */
.post-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.user-meta {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
}

.post-time {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 6rpx;
}

.category-tag {
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* 帖子内容 */
.post-content {
  margin-bottom: 30rpx;
}

.content-text {
  display: block;
  font-size: 32rpx;
  color: var(--text);
  line-height: 1.8;
  word-break: break-all;
  white-space: pre-wrap;
}

.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.tag {
  font-size: 24rpx;
  color: var(--primary);
  background: var(--primary-light);
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
}

/* 帖子统计 */
.post-stats {
  display: flex;
  gap: 40rpx;
  padding: 20rpx 0;
  border-top: 2rpx solid #f5f5f5;
  border-bottom: 2rpx solid #f5f5f5;
  margin-bottom: 30rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 26rpx;
  color: var(--text-light);
}

.stat-icon {
  font-size: 28rpx;
}

/* 操作按钮 */
.post-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--text);
}

.action-btn.active {
  background: #ffebee;
  color: #FF6B6B;
}

.action-icon {
  font-size: 32rpx;
}

.share-btn {
  background: #e3f2fd;
  color: #1976d2;
  padding: 0;
  margin: 0;
  line-height: inherit;
}

.share-btn::after {
  border: none;
}

/* 评论区 */
.comments-section {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 200rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
}

/* 评论列表 */
.comment-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.comment-item {
  display: flex;
  gap: 20rpx;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.comment-body {
  flex: 1;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.comment-author {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}

.comment-time {
  font-size: 22rpx;
  color: var(--text-light);
}

.comment-content {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.6;
  margin-bottom: 16rpx;
  word-break: break-all;
}

.reply-to {
  color: var(--primary);
  font-weight: 500;
}

.comment-actions {
  display: flex;
  gap: 30rpx;
}

.comment-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--text-light);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.comment-action.liked {
  color: #FF6B6B;
}

.comment-action:active {
  background: #f5f5f5;
}

/* 空评论 */
.empty-comments {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text);
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-light);
}

/* 评论输入栏 */
.comment-input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.reply-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: var(--text-light);
}

.cancel-reply {
  font-size: 32rpx;
  color: #999;
  padding: 10rpx;
}

.input-row {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.comment-input {
  flex: 1;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}

.send-btn {
  width: 120rpx;
  height: 80rpx;
  background: #e0e0e0;
  color: #999;
  border-radius: 40rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
}

.send-btn.active {
  background: var(--primary);
  color: white;
}

.send-btn::after {
  border: none;
}
